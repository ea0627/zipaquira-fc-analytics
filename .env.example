# Hattrick CHPP credentials
# Copy this file to .env.local and replace the values with your real credentials.

CHPP_CONSUMER_KEY=your_consumer_key_here
CHPP_CONSUMER_SECRET=your_consumer_secret_here

# Future OAuth tokens
CHPP_ACCESS_TOKEN=your_access_token_here
CHPP_ACCESS_SECRET=your_access_secret_here